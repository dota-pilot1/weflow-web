# Supabase
# 대시보드 → Settings → API 에서 발급
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# 어드민 세션 쿠키 서명용 시크릿
# 생성: openssl rand -hex 32
ADMIN_SESSION_SECRET=64자리_랜덤_헥스_문자열

# NCP(Naver Cloud Platform) SENS SMS — 접수 완료 시 고객에게 조회코드 안내 문자 발송
# SMS_PROVIDER=sens 일 때만 실제 발송. 미설정/sens 아님 → mock(콘솔 로그)
# 발신번호(NCP_SMS_FROM)는 NCP 콘솔에 사전등록된 번호여야 함
SMS_PROVIDER=mock
NCP_SENS_SERVICE_ID=ncp:sms:kr:000000000000:your-sms-service
NCP_ACCESS_KEY=ncp_iam_xxxxxxxxxxxx
NCP_SECRET_KEY=ncp_iam_xxxxxxxxxxxx
NCP_SMS_FROM=01000000000
